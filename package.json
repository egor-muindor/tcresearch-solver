{
  "name": "gtnh-research-solver",
  "private": true,
  "version": "2.0.0",
  "description": "Standalone solver for the Thaumcraft / GregTech: New Horizons research hex minigame.",
  "license": "MIT",
  "author": "Egor Fadeev",
  "repository": {
    "type": "git",
    "url": "https://github.com/egor-muindor/tcresearch-solver.git"
  },
  "type": "module",
  "packageManager": "bun@1.3.14",
  "scripts": {
    "copy-assets": "node scripts/copy-assets.mjs",
    "dev": "node scripts/copy-assets.mjs && vite",
    "typecheck": "tsc --noEmit",
    "build": "node scripts/copy-assets.mjs && tsc --noEmit && vite build",
    "preview": "vite preview --base /tcresearch-solver/",
    "test": "bun test"
  },
  "devDependencies": {
    "bun-types": "1.3.14",
    "typescript": "5.6.3",
    "vite": "5.4.10"
  }
}
